{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "totalPrice": {
      "type": "float"
    },
    "customerName": {
      "type": "string"
    },
    "customerEmail": {
      "type": "string"
    },
    "shippingAddress": {
      "type": "text"
    },
    "products": {
      "type": "json"
    },
    "statuss": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "pending",
        "paid",
        "shipped"
      ]
    }
  }
}
