{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "price": {
      "type": "integer"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "single_origin",
        "blend",
        "filtre_kahve",
        "espresso"
      ]
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "acidity": {
      "type": "integer"
    },
    "body": {
      "type": "integer"
    },
    "roast": {
      "type": "integer"
    },
    "tasteProfile": {
      "type": "string"
    }
  }
}
